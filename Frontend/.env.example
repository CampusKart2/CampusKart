# Database -- AWS RDS PostgreSQL
DATABASE_URL=postgresql://user:password@your-rds-host.region.rds.amazonaws.com:5432/postgres

# JWT Auth (use a long random string in production)
JWT_SECRET=your-jwt-secret-min-32-chars

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
EMAIL_FROM=your-email@gmail.com

# Moderation — receives the one-time alert when a listing hits the report threshold
ADMIN_REPORT_EMAIL=admin@your-domain.com

# GetStream (Stream Chat) — webhooks ([04.01] message alerts)
# Secret: HMAC-SHA256 of raw body (X-Signature). Key: must match X-Api-Key when set.
GETSTREAM_API_KEY=
GETSTREAM_API_SECRET=
# Same key as GETSTREAM_API_KEY — exposed to the browser for the Stream Chat client (unread badge).
NEXT_PUBLIC_GETSTREAM_API_KEY=
